DJANGO_SECRET_KEY=change-me-to-a-random-secret-key
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# Origines autorisées pour les requêtes POST (avec le schéma, ex: https://mondomaine.exemple)
DJANGO_CSRF_TRUSTED_ORIGINS=

POSTGRES_DB=entrainement_medecine
POSTGRES_USER=entrainement_medecine
POSTGRES_PASSWORD=change-me

# Port externe sur lequel nginx écoute (mappé par docker-compose)
NGINX_PORT=8080

# Dossier hôte pour les données persistantes (postgres/media/static) et chemin
# du fichier nginx.conf. Laisser vide en local (valeurs par défaut relatives
# au repo) ; à fixer en chemin absolu pour un déploiement type Portainer où le
# répertoire de travail du stack n'est pas garanti (ex: /docker/studymed/data,
# /docker/studymed/nginx.conf).
DATA_DIR=
NGINX_CONF_PATH=
