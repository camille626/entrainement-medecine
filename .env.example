DJANGO_SECRET_KEY=change-me-to-a-random-secret-key
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# Origines autorisées pour les requêtes POST (avec le schéma, ex: https://mondomaine.exemple)
DJANGO_CSRF_TRUSTED_ORIGINS=

POSTGRES_DB=entrainement_medecine
POSTGRES_USER=entrainement_medecine
POSTGRES_PASSWORD=change-me

# Port externe sur lequel nginx écoute (mappé par docker-compose)
NGINX_PORT=8080

# Dossier de base pour les données persistantes (postgres/media/static).
# Laisser vide en local (par défaut : relatif au repo, ./data/...).
# À fixer en chemin absolu pour un déploiement Portainer (ex: /volume1/docker/studymed),
# pour que les données survivent à une suppression/recréation du stack.
STORAGE_DIR=
